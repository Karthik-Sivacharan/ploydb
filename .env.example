# PloyDB — Environment Variables
# Copy this file to .env.local and fill in the values
# cp .env.example .env.local

# Required — Mock CRM database hosted on Railway
# The demo loads 960 contacts + companies from this API
NEXT_PUBLIC_PLOYDB_API_URL=
NEXT_PUBLIC_PLOYDB_TOKEN=

# Optional — Anthropic Claude API for email generation (demo step 8)
# Without this, template fallback emails are used
ANTHROPIC_API_KEY=

# Optional — Brandfetch API for brand logos in connected sources
# Without this, hardcoded CDN logos are used
NEXT_PUBLIC_BRANDFETCH_API_KEY=
